{
  "name": "glide",
  "version": "0.1.0",
  "description": "Multi-account Google workspace browser for macOS",
  "private": true,
  "license": "GPL-3.0-only",
  "author": "Brandon Camp",
  "main": "out/main/index.js",
  "scripts": {
    "start": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:smoke": "playwright test tests/smoke.spec.ts",
    "test:isolation": "playwright test tests/isolation.spec.ts",
    "guard": "node scripts/guard.mjs",
    "package": "npm run build && electron-builder --dir -c.mac.identity=null -c.mac.notarize=false",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^37.10.3",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.bcamp.glide",
    "productName": "Glide",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/glide-app-icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "target": [
        { "target": "dmg", "arch": "arm64" }
      ],
      "extendInfo": {
        "NSBluetoothAlwaysUsageDescription": "Glide uses Bluetooth for passkey (security key) sign-in.",
        "NSBluetoothPeripheralUsageDescription": "Glide uses Bluetooth for passkey (security key) sign-in.",
        "NSCameraUsageDescription": "Glide lets Google apps such as Meet use the camera.",
        "NSMicrophoneUsageDescription": "Glide lets Google apps such as Meet use the microphone."
      }
    }
  },
  "dependencies": {
    "electron-chrome-extensions": "^4.9.0",
    "electron-chrome-web-store": "^0.13.0"
  }
}
